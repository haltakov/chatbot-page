# Copy to .env.local and fill in to enable the real LLM/RAG backend.
# Without these, /api/chat streams a placeholder response.

# OpenAI Responses API (model provider)
OPENAI_API_KEY=
OPENAI_ORGANIZATION_ID=
OPENAI_PROJECT_ID=
# Optional: defaults to gpt-5.4-mini
OPENAI_MODEL=gpt-5.4-mini
# Optional: comma-separated OpenAI vector store IDs to enable file_search/RAG
OPENAI_VECTOR_STORE_ID=

# Telegram notifier (optional) - used by /api/chatbot-events.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: if set, instrumentation.ts registers this URL with Telegram on app startup.
TELEGRAM_WEBHOOK_URL=https://example.com/api/telegram-webhook
# Optional but recommended for /api/telegram-webhook. Use this as Telegram's
# secret_token when setting the webhook URL.
TELEGRAM_WEBHOOK_SECRET=
# Optional: lock operator replies to one Telegram user id inside TELEGRAM_CHAT_ID.
TELEGRAM_ADMIN_USER_ID=
