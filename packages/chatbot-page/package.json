{
  "name": "chatbot-page",
  "version": "0.1.0",
  "description": "A configurable chatbot-style page for personal sites, company pages, and LLM-backed Q&A.",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "./dist/styles.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsup src/index.ts src/server/index.ts --format esm --dts --sourcemap --clean && cp src/styles.css dist/styles.css",
    "dev": "tsup src/index.ts src/server/index.ts --format esm --dts --sourcemap --watch --onSuccess \"cp src/styles.css dist/styles.css\"",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "unique-names-generator": "^4.7.1"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsup": "^8.5.0",
    "typescript": "5.7.3"
  }
}
